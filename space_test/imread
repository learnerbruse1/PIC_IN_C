#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <setjmp.h>

/* ---------- 统一的图像结构体 ---------- */
typedef struct {
    unsigned char *data;      // 像素数据（行优先，RGB交错或灰度）
    int width;
    int height;
    int channels;             // 1,3,4
    unsigned char *colormap;  // 颜色表（非索引图像为NULL）
    int colormap_len;         // 颜色表长度（0表示无）
    int is_indexed;           // 是否为索引图像（JPEG/PNG真彩为0）
} ImageStruct;

/* 错误处理（同前） */
struct my_error_mgr {
    struct jpeg_error_mgr pub;
    jmp_buf setjmp_buffer;
};
typedef struct my_error_mgr *my_error_ptr;

static void my_error_exit(j_common_ptr cinfo) {
    my_error_ptr myerr = (my_error_ptr) cinfo->err;
    (*cinfo->err->output_message)(cinfo);
    longjmp(myerr->setjmp_buffer, 1);
}

/* JPEG 解码器（内部使用） */
static ImageStruct read_jpeg(const char *filename) {
    ImageStruct img = {NULL, 0, 0, 0, NULL, 0, 0};
    FILE *infile;
    struct jpeg_decompress_struct cinfo;
    struct my_error_mgr jerr;
    JSAMPARRAY buffer;
    int row_stride;

    if ((infile = fopen(filename, "rb")) == NULL) {
        fprintf(stderr, "无法打开文件 %s\n", filename);
        return img;
    }

    cinfo.err = jpeg_std_error(&jerr.pub);
    jerr.pub.error_exit = my_error_exit;
    if (setjmp(jerr.setjmp_buffer)) {
        jpeg_destroy_decompress(&cinfo);
        fclose(infile);
        return img;
    }

    jpeg_create_decompress(&cinfo);
    jpeg_stdio_src(&cinfo, infile);
    jpeg_read_header(&cinfo, TRUE);
    jpeg_start_decompress(&cinfo);

    img.width  = cinfo.output_width;
    img.height = cinfo.output_height;
    img.channels = cinfo.output_components; // 1或3
    img.is_indexed = 0;                     // JPEG 无颜色表
    row_stride = img.width * img.channels;

    img.data = (unsigned char*)malloc(row_stride * img.height);
    if (!img.data) {
        jpeg_destroy_decompress(&cinfo);
        fclose(infile);
        return img;
    }

    buffer = (*cinfo.mem->alloc_sarray)((j_common_ptr)&cinfo, JPOOL_IMAGE, row_stride, 1);
    unsigned char *ptr = img.data;
    while (cinfo.output_scanline < cinfo.output_height) {
        jpeg_read_scanlines(&cinfo, buffer, 1);
        memcpy(ptr, buffer[0], row_stride);
        ptr += row_stride;
    }

    jpeg_finish_decompress(&cinfo);
    jpeg_destroy_decompress(&cinfo);
    fclose(infile);
    return img;
}

/* ---------- 对外统一的 imread 接口 ---------- */
ImageStruct imread(const char *filename) {
    /* 根据文件扩展名（或魔数）选择解码器 */
    const char *ext = strrchr(filename, '.');
    if (ext && (strcmp(ext, ".jpg") == 0 || strcmp(ext, ".jpeg") == 0)) {
        return read_jpeg(filename);
    }
    else {
        fprintf(stderr, "不支持的图像格式: %s\n", ext ? ext : "未知");
        ImageStruct err = {NULL, 0, 0, 0, NULL, 0, 0};
        return err;
    }
}

/* 释放图像结构体的内存 */
void imfree(ImageStruct *img) {
    if (img->data) free(img->data);
    if (img->colormap) free(img->colormap);
    img->data = img->colormap = NULL;
    img->width = img->height = img->channels = img->colormap_len = img->is_indexed = 0;
}